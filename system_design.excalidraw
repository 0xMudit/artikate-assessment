    {
      "id": "s2_lua_t",
      "type": "text",
      "x": 720,
      "y": 540,
      "width": 520,
      "height": 110,
      "text": "Redis Lua Script (atomic rate limiter)\nZREMRANGEBYSCORE  -- prune old entries\nZCARD              -- count in window\nif count < 200:\n  INCR seq         -- unique member ID\n  ZADD now-seq     -- record timestamp\n  PEXPIRE          -- set TTL\n  return 1         -- allowed\nelse:\n  return 0         -- rate limited",
      "originalText": "Redis Lua Script (atomic rate limiter)\nZREMRANGEBYSCORE  -- prune old entries\nZCARD              -- count in window\nif count < 200:\n  INCR seq         -- unique member ID\n  ZADD now-seq     -- record timestamp\n  PEXPIRE          -- set TTL\n  return 1         -- allowed\nelse:\n  return 0         -- rate limited",
      "fontSize": 13,
      "fontFamily": 3,
      "strokeColor": "#0c8599",
      "backgroundColor": "transparent",
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "s2_lua_box",
