    {
      "id": "s3_strategies_t",
      "type": "text",
      "x": 1390,
      "y": 730,
      "width": 520,
      "height": 60,
      "text": "Middleware Strategies (priority order):\n1. X-Tenant-ID Header  |  2. JWT Bearer Token (tenant_id claim)\n3. Subdomain (acme.example.com)  |  4. Query Param ?tenant=\nFail-safe: no tenant -> queryset.none() (empty result)",
      "originalText": "Middleware Strategies (priority order):\n1. X-Tenant-ID Header  |  2. JWT Bearer Token (tenant_id claim)\n3. Subdomain (acme.example.com)  |  4. Query Param ?tenant=\nFail-safe: no tenant -> queryset.none() (empty result)",
      "fontSize": 13,
